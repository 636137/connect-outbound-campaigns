# .gitignore for Amazon Connect Outbound Campaigns

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# AWS
.aws/
*.pem

# Logs
*.log
logs/

# Test
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
*.yaml.bak
bundle.json
import-report.json
verify.json

# --- Maximus security hardening (do not commit secrets) ---
.env
.env.*
!.env.example

# Private keys / certs / keystores
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_dsa

# Terraform state
*.tfstate
*.tfstate.*

# Logs
*.log
node_modules/
